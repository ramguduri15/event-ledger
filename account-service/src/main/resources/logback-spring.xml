<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="springAppName" source="spring.application.name"
                    defaultValue="account-service"/>

    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <!--
                Emit one JSON object per line so log aggregators (Loki, CloudWatch, etc.)
                can parse each entry without multiline handling.
            -->
            <pattern>{"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSS'Z',UTC}","level":"%level","service":"${springAppName}","traceId":"%X{traceId:-none}","logger":"%logger{36}","message":"%replace(%msg){'\"','\\\"'}"}%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="JSON_CONSOLE"/>
    </root>

    <!-- Reduce noise from Hibernate and H2 -->
    <logger name="org.hibernate" level="WARN"/>
    <logger name="com.h2database" level="WARN"/>
    <logger name="org.springframework.web" level="INFO"/>

</configuration>
